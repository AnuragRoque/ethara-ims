# ─────────────────────────────────────────────────────────────────────────────
#  Ethara IMS — environment variables (single source of truth)
#  Copy this file to `.env` and fill in real values. Never commit the real .env.
# ─────────────────────────────────────────────────────────────────────────────

#  Database (PostgreSQL) — used by the `db` service AND the backend.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=ethara_ims

#  Native (non-Docker) local dev only. Under Docker Compose these are ignored —
#  the backend's DATABASE_URL is built automatically and points at the `db` host.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

#  Backend.
#  For a managed/external database (e.g. Render), set DATABASE_URL directly and
#  it takes precedence over the POSTGRES_* parts above.
# DATABASE_URL=postgresql+psycopg://postgres:change-me@db:5432/ethara_ims
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
LOW_STOCK_THRESHOLD=10

#  Seed demo products/customers on first boot (idempotent). Set to false for prod.
SEED_ON_STARTUP=true

#  Frontend — inlined into the bundle by Vite at build time.
VITE_API_BASE_URL=http://localhost:8000
